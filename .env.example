ANTHROPIC_API_KEY=your_key_here

# Option A — Upstash (paste the full rediss:// URL from your Upstash dashboard)
REDIS_URL=rediss://:your_password@your-endpoint.upstash.io:6379

# Option B — local Redis (comment out REDIS_URL and use these instead)
#REDIS_HOST=localhost
#REDIS_PORT=6379
#REDIS_DB=0
#REDIS_PASSWORD=

MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password
MT5_SERVER=FusionMarkets-Demo

MAX_DRAWDOWN_PCT=5.0
MAX_POSITION_SIZE_USD=10000
MAX_DAILY_LOSS_USD=500
MAX_OPEN_POSITIONS=10
ALLOWED_SYMBOLS=EURUSD,GBPUSD,USDJPY,XAUUSD

LOG_LEVEL=INFO
ENVIRONMENT=development
